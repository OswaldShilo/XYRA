# FLUX Configuration File
# Copy to .env and fill in with your values

# OpenWeather API (free tier at https://openweathermap.org/api)
# Get your key: https://openweathermap.org/api
OPENWEATHER_API_KEY=demo

# Google Calendar API (optional, free tier)
GOOGLE_CALENDAR_API_KEY=

# Store Configuration
STORE_PINCODE=600001
LEAD_TIME_DAYS=2

# FastAPI
LOG_LEVEL=info
